## Plurals + autofill + profile-confirm
settings-privacy-ads-blocked =
    { $count ->
        [one] { $count } solicitud de anuncio/rastreador bloqueada en esta sesión.
       *[other] { $count } solicitudes de anuncios/rastreadores bloqueadas en esta sesión.
    }
why-sub =
    { $count ->
        [one] { $count } solicitud que el bloqueador de anuncios/rastreadores detuvo en la página que estabas viendo, agrupada por host. Calculado en el dispositivo; nada salió de la máquina.
       *[other] { $count } solicitudes que el bloqueador de anuncios/rastreadores detuvo en la página que estabas viendo, agrupadas por host. Calculado en el dispositivo; nada salió de la máquina.
    }
