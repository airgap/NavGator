diff --git a/style/properties/longhands.toml b/style/properties/longhands.toml
index bd8f336d6..979b54287 100644
--- a/style/properties/longhands.toml
+++ b/style/properties/longhands.toml
@@ -3614,7 +3614,10 @@ affects = "paint"
