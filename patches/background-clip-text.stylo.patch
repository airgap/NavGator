 vector = {}
-keyword = { values = ["border-box", "padding-box", "content-box"], extra_gecko_values = ["text"], gecko_enum_prefix = "StyleGeometryBox", gecko_inexhaustive = true }
+# `text` is promoted from `extra_gecko_values` into the shared `values` so that the
+# Servo engine also gets a `Clip::Text` variant. This enables `background-clip: text`
