+fn is_avif(buffer: &[u8]) -> bool {
+    // AVIF is ISOBMFF: [4-byte big-endian box size][b"ftyp"][major brand][minor version]
+    // [compatible brands…]. Files carry the "avif" (still) or "avis" (sequence) brand as the
+    // major or a compatible brand; scan the `ftyp` box's brand list for either.
+    if buffer.len() < 12 || &buffer[4..8] != b"ftyp" {
+        return false;
+    }
+    let box_size = u32::from_be_bytes([buffer[0], buffer[1], buffer[2], buffer[3]]) as usize;
+    let end = box_size.clamp(12, buffer.len());
+    buffer[8..end]
+        .windows(4)
+        .any(|brand| brand == b"avif" || brand == b"avis")
+}
