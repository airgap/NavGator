+    /// Resolve an index name to its `(id, unique)` within an object store, or `None` if absent.
+    fn lookup_index(
+        connection: &Connection,
+        object_store_id: i32,
+        index_name: &str,
+    ) -> Result<Option<(i64, bool)>, Error> {
