+                         (index_id, value, object_store_id, object_data_key) VALUES (?, ?, ?, ?)",
+                        params![
+                            index_id,
+                            serialized_index_value,
+                            object_store_id,
+                            serialized_primary_key
+                        ],
+                    )?;
+                } else {
+                    connection.execute(
+                        "INSERT INTO index_data \
+                         (index_id, value, object_data_key, object_store_id) VALUES (?, ?, ?, ?)",
+                        params![
+                            index_id,
+                            serialized_index_value,
