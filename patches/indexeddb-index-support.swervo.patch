+                    "SELECT id, unique_index, multi_entry_index FROM object_store_index \
+                     WHERE name = ? AND object_store_id = ?",
+                )
+                .and_then(|mut stmt| {
+                    stmt.query_row(params![index_name, object_store_id], |row| {
+                        Ok((
+                            row.get::<_, i64>(0)?,
+                            row.get::<_, bool>(1)?,
+                            row.get::<_, bool>(2)?,
+                        ))
+                    })
+                    .optional()
+                })?;
