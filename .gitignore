# Rust build output (Servo deps make this many GB)
/target

# Vendored Verso source — archived upstream, ~hundreds of MB, NOT our code.
# Re-fetch with: git clone --depth 1 https://github.com/versotile-org/verso.git reference/verso
/reference

# Servo's lockfile, copied in during setup if needed (see docs/ARCHITECTURE.md).
# Comment this out if you decide to commit a pinned lockfile.
# /Cargo.lock

# Local machine build env — pins LIBCLANG_PATH for this box's mixed llvm-18/21
# (mozangle/bindgen otherwise picks the wrong libclang). Linux-specific; not for CI/mac.
/.cargo/config.toml

# Editor / OS noise
.DS_Store
*.swp
/.idea
/.vscode
__pycache__/

# Runtime / test cruft (Servo per-origin IndexedDB "bottles" written when the engine
# runs from the repo cwd; never source)
/bottles/
