<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened-runtime entitlements required for notarization to actually RUN.
         NavGator embeds SpiderMonkey, which JITs JavaScript: it must allocate and
         execute writable memory, which the hardened runtime forbids by default. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Servo loads GStreamer plugins (and other dylibs) we don't sign ourselves;
         without this the hardened runtime refuses to load them and media breaks. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
